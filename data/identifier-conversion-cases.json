{
  "version": 1,
  "updated": "2026-07-12",
  "status": "deterministic-source-backed-verification-fixtures",
  "scope": "Representative zero-network identifier conversion fixtures. These cases verify documented lookup and formatting boundaries; they are not a complete MoonCat mapping table or current ownership snapshot.",
  "sourceRefs": [
    "mooncatrescue-libmooncat-limited-js",
    "mooncatrescue-mooncat-traits-json",
    "etherscan-acclimated-mooncats",
    "etherscan-mooncats-wrapped",
    "etherscan-mooncat-accessories",
    "ponderware-mooncatrescue-sol-raw"
  ],
  "typeDefinitions": {
    "catIdBytes5": "Canonical MoonCat bytes5 identity represented as a lowercase 0x-prefixed string with exactly 10 hexadecimal digits.",
    "rescueOrder": "Integer API/original rescue index in the closed checked range 0 through 25439.",
    "acclimatedTokenId": "Integer ERC-721 token ID for the exact Acclimated MoonCats contract; source-backed equivalent to rescueOrder for that contract only.",
    "wmcrTokenId": "Integer MoonCatsWrapped / WMCR wrapper token ID allocated by that contract's counter and resolved through its mapping, not through rescue order.",
    "accessoryId": "MoonCatAccessories definition-array index; not a MoonCat identity.",
    "paletteIndex": "Slot index within one accessory definition palette; not a global color or MoonCat identity.",
    "ownedAccessoryIndex": "Local zero-based index within one rescueOrder's OwnedAccessory array; not an accessoryId or MoonCat identity.",
    "managedAccessoryIndex": "Local manager enumeration index that resolves to an accessoryId; not a MoonCat identity.",
    "batchOwnedAccessoryIndex": "Index field used by an accessory batch operation; context-bound and not a MoonCat identity.",
    "marketplaceUrlIdentifier": "Marketplace URL path value whose meaning depends on collection contract and URL context; not a generic conversion input."
  },
  "conversionDefinitions": {
    "rescueOrder_to_catIdBytes5": {
      "inputType": "rescueOrder",
      "outputType": "catIdBytes5",
      "status": "supported",
      "reversibility": "bijective-for-known-rescued-fixture-domain",
      "method": "LibMoonCat.getMoonCatIdByRescueIndex/getCatId array-backed lookup, cross-checked against mooncat_traits.json[rescueOrder].catId",
      "sourceRefs": ["mooncatrescue-libmooncat-limited-js", "mooncatrescue-mooncat-traits-json"]
    },
    "catIdBytes5_to_rescueOrder": {
      "inputType": "catIdBytes5",
      "outputType": "rescueOrder",
      "status": "supported",
      "reversibility": "bijective-for-known-rescued-fixture-domain",
      "method": "Strict 0x-prefixed bytes5 normalization followed by LibMoonCat.getRescueOrder array-backed lookup",
      "sourceRefs": ["mooncatrescue-libmooncat-limited-js", "mooncatrescue-mooncat-traits-json"]
    },
    "acclimatedTokenId_to_catIdBytes5": {
      "inputType": "acclimatedTokenId",
      "outputType": "catIdBytes5",
      "status": "supported",
      "reversibility": "contextual-one-step-then-bijective-lookup",
      "method": "For the exact Acclimated MoonCats contract only, treat tokenId as rescueOrder, then apply rescueOrder_to_catIdBytes5",
      "sourceRefs": ["etherscan-acclimated-mooncats", "mooncatrescue-libmooncat-limited-js", "mooncatrescue-mooncat-traits-json"]
    },
    "acclimatedTokenId_to_rescueOrder": {
      "inputType": "acclimatedTokenId",
      "outputType": "rescueOrder",
      "status": "supported",
      "reversibility": "contextual-identity-for-exact-contract",
      "method": "Exact Acclimated contract source documents minted tokenId as rescueOrder",
      "sourceRefs": ["etherscan-acclimated-mooncats"]
    },
    "wmcrTokenId_to_catIdBytes5": {
      "inputType": "wmcrTokenId",
      "outputType": "catIdBytes5",
      "status": "unsupported-without-exact-mapping-state",
      "reversibility": "contextual-mapping-backed",
      "method": "Requires the exact MoonCatsWrapped _tokenIDToCatID mapping or wrap/unwrap event context; no mapping contents are imported",
      "sourceRefs": ["etherscan-mooncats-wrapped"]
    },
    "wmcrTokenId_to_rescueOrder": {
      "inputType": "wmcrTokenId",
      "outputType": "rescueOrder",
      "status": "unsupported-direct-conversion",
      "reversibility": "unsupported",
      "method": "Resolve WMCR tokenId to bytes5 through the exact wrapper mapping first, then perform the separate bytes5 lookup",
      "sourceRefs": ["etherscan-mooncats-wrapped", "mooncatrescue-libmooncat-limited-js"]
    },
    "nonMoonCatIdentity_to_catIdBytes5": {
      "inputType": "accessoryId-or-context-index",
      "outputType": "catIdBytes5",
      "status": "unsupported",
      "reversibility": "unsupported",
      "method": "Accessory definition, palette, owned-record, manager, batch, and marketplace indexes are separate identifier spaces",
      "sourceRefs": ["etherscan-mooncat-accessories", "etherscan-acclimated-mooncats"]
    }
  },
