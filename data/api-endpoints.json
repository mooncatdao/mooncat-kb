  "migrationNotes": [
    {
      "key": "preferred-api",
      "notes": "Use https://api.mooncatrescue.com for new integrations when possible."
    },
    {
      "key": "legacy-api-valid",
      "notes": "https://api.mooncat.community is recorded as legacy-valid, not broken. It may be deprecated later, so avoid new dependencies unless a legacy-only endpoint is required."
    },
    {
      "key": "path-prefixes",
      "notes": "The preferred API groups MoonCat paths under /mooncat/... while the legacy API uses root-level paths such as /traits/... and several image variant paths."
    },
    {
      "key": "events-path",
      "notes": "The preferred API /events endpoint is listed under Blockchain. The legacy API /events endpoint is tied to older event/holiday accessory behavior. Do not treat them as interchangeable."
    },
    {
      "key": "identifier-conversion",
      "notes": "Endpoint parameters that accept rescue indexes still require a verified conversion/mapping step before use with token IDs, bytes5 catIds, OpenSea IDs, or local rescue-order bucket indexes."
    }
  ],
  "todos": [
    "Import full request and response schemas only in a focused schema pass.",
    "Verify query parameters before building client code from these summaries.",
    "Monitor whether the legacy API receives a formal deprecation notice.",
    "Document any verified conversion between original rescue index, rescue-order index, bytes5 catId, and token-facing identifiers."
  ]
}
