  "identifierConventions": [
    {
      "key": "catId_or_rescueIndex",
      "status": "documented",
      "acceptedIdentifiers": [
        {
          "kind": "mooncat-id",
          "example": "0x00d8523a53"
        },
        {
          "kind": "original-rescue-index",
          "range": {
            "min": 0,
            "max": 25439
          }
        }
      ],
      "sourceRefs": [
        "mooncatrescue-api",
        "mooncat-community-api"
      ],
      "notes": "The documented parameter can accept a valid MoonCat ID or an original rescue index. The API-documented `rescueIndex` accepts original rescue indexes in the range 0–25439. Local rescue-order-index values have been verified as aligned with API rescueOrder/original rescue index by local bucket checks and preferred API samples. These indexes are still not token IDs, OpenSea IDs, bytes5 catIds, or contract call values."
    },
    {
      "key": "ethAddress",
      "status": "documented",
      "acceptedIdentifiers": [
        {
          "kind": "ethereum-address"
        }
      ],
      "sourceRefs": [
        "mooncatrescue-api",
        "mooncat-community-api"
      ],
      "notes": "Used by owner/profile and owned-MoonCat endpoints. Address normalization behavior is not documented here."
    },
    {
      "key": "accessoryId",
      "status": "documented",
      "acceptedIdentifiers": [
        {
          "kind": "accessory-id"
        }
      ],
      "sourceRefs": [
        "mooncatrescue-api",
        "mooncat-community-api"
      ],
      "notes": "Accessory ID format and validation rules are not imported in this pass."
    }
